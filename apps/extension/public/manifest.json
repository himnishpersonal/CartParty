{
  "manifest_version": 3,
  "name": "CartParty Save",
  "description": "Save products into a shared CartParty collection.",
  "version": "0.1.0",
  "action": {
    "default_popup": "index.html",
    "default_title": "Save to CartParty"
  },
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["http://localhost:4000/*", "https://*/*"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["assets/content.js"],
      "run_at": "document_idle"
    }
  ]
}
